# Supabase (te vinden in Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google Maps (te vinden in Google Cloud Console → APIs & Services → Credentials)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIza...

# Unsplash (te vinden op unsplash.com/oauth/applications)
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your_key_here

# Admin wachtwoord voor /admin
ADMIN_PASSWORD=kies-een-sterk-wachtwoord

# Overpass API (optioneel — standaard publieke instantie)
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
